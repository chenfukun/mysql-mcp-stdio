{
  "name": "mysql-mcp-stdio",
  "version": "1.0.0",
  "description": "An MCP stdio server that provides read-only access to MySQL databases.",
  "type": "module",
  "bin": {
    "mysql-mcp-stdio": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "keywords": [
    "mcp",
    "mysql",
    "database",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/chenfukun/mysql-mcp-stdio.git"
  },
  "author": "john",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  }
}
